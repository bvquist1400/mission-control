        "options": {
          "appendAttribution": false
        }
      },
      "id": "1c8ff998-a269-4449-bf44-b86323058f74",
      "name": "Send Midday Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        -360,
        20
      ]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "45 16 * * 1-5"
            }
          ]
        }
      },
      "id": "f74b2023-1d71-438e-b766-8638bb056c8a",
